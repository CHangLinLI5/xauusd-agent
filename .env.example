# =============================================================================
# xauusd-agent Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ---------- Core ----------

# Node environment: "development" or "production"
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# ---------- Database (required) ----------

# PostgreSQL connection string (Neon serverless recommended)
# Example: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ---------- Authentication (required in production) ----------

# Secret key for signing JWT session tokens
# MUST be a strong random string in production (min 32 characters)
# In development, a default dev secret is used if not set
JWT_SECRET=

# Manus OAuth server URL (optional, for Manus OAuth login)
OAUTH_SERVER_URL=

# Manus App ID (optional, for Manus OAuth login)
VITE_APP_ID=

# Owner's OpenID — this user is automatically promoted to admin role
OWNER_OPEN_ID=

# ---------- Market Data ----------

# Twelve Data API key for XAU/USD real-time price and K-line data
# Get your free key at https://twelvedata.com/
# Required in production; without it, market data falls back to mock
TWELVE_DATA_API_KEY=

# ---------- AI / LLM ----------

# Custom LLM API endpoint (OpenAI-compatible)
CUSTOM_LLM_API_URL=

# Custom LLM API key
CUSTOM_LLM_API_KEY=

# Custom LLM model name (default: gpt-5.4)
CUSTOM_LLM_MODEL=gpt-5.4

# Alternative: OpenAI-compatible API (used as fallback if CUSTOM_LLM is not set)
# OPENAI_BASE_URL=
# OPENAI_API_KEY=

# Forge API (Manus built-in LLM proxy, optional)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ---------- Security / CORS ----------

# Comma-separated list of allowed origins for Socket.IO CORS
# Example: https://yourdomain.com,https://www.yourdomain.com
# If not set, all origins are allowed (suitable for development only)
ALLOWED_ORIGINS=

# ---------- Development Options ----------

# Allow JWT-based auth fallback when DB is unavailable (dev only, never in production)
# ALLOW_JWT_FALLBACK=true

# Run integration tests that require real API keys and network access
# RUN_INTEGRATION_TESTS=0
